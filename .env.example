SUPERBRAIN_ENV=dev
SUPERBRAIN_LOG_LEVEL=INFO
SUPERBRAIN_API_HOST=0.0.0.0
SUPERBRAIN_API_PORT=8000
SUPERBRAIN_DATABASE_URL=postgresql+psycopg://superbrain:superbrain@localhost:5432/superbrain
SUPERBRAIN_TELEGRAM_BOT_TOKEN=
SUPERBRAIN_MODEL_RUNTIME=local_stub
SUPERBRAIN_LOCAL_MODEL_BASE_URL=http://localhost:11434
SUPERBRAIN_EMBEDDING_MODEL_NAME=nomic-embed-text
SUPERBRAIN_EMBEDDING_DIMENSIONS=16
SUPERBRAIN_GENERATION_MODEL_NAME=llama3.1:8b
SUPERBRAIN_MODEL_REQUEST_TIMEOUT_SECONDS=30
SUPERBRAIN_MODEL_MAX_RETRIES=2
SUPERBRAIN_SCHEDULER_ENABLED=false
SUPERBRAIN_SCHEDULER_DIGEST_CRON=0 7 * * *
SUPERBRAIN_METRICS_BACKEND=prometheus
SUPERBRAIN_FEATURE_ENABLE_DIGEST=true
SUPERBRAIN_FEATURE_ENABLE_TOPIC_CLASSIFICATION=true
SUPERBRAIN_FEATURE_ENABLE_INGESTION_API=true
