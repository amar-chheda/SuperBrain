SUPERBRAIN_DATABASE_URL=postgresql+asyncpg://superbrain:superbrain@localhost:5432/superbrain
SUPERBRAIN_OLLAMA_BASE_URL=http://localhost:11434
SUPERBRAIN_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
SUPERBRAIN_OLLAMA_QA_MODEL=llama3.1:8b
SUPERBRAIN_OLLAMA_CLASSIFICATION_MODEL=phi3:mini
SUPERBRAIN_OLLAMA_DIGEST_MODEL=llama3.1:8b
SUPERBRAIN_CRAWLER_BACKEND=httpx
SUPERBRAIN_LOG_LEVEL=INFO
SUPERBRAIN_LOG_FORMAT=text

# Telegram (optional — ngrok tunnel + webhook registration happens automatically on startup)
# SUPERBRAIN_TELEGRAM_BOT_TOKEN=your-bot-token
# SUPERBRAIN_NGROK_AUTHTOKEN=your-ngrok-authtoken   # optional, uses system ngrok config if omitted
# SUPERBRAIN_TELEGRAM_WEBHOOK_URL=https://yourserver.com  # set in prod to skip ngrok entirely
